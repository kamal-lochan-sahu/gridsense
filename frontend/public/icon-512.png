</span></span><span><span>    description</span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span class="token token" style="color: rgb(0, 128, 0);">"Real-Time Industrial Energy Intelligence Platform"</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>    version</span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span class="token token" style="color: rgb(0, 128, 0);">"1.0.0"</span><span>
