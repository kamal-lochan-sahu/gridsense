</span></span><span><span>    allow_methods</span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"*"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
