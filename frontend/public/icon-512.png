</span></span><span><span></span><span class="token token" style="color: rgb(129, 0, 194);">from</span><span> datetime </span><span class="token token" style="color: rgb(129, 0, 194);">import</span><span> datetime</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span> timedelta
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(110, 118, 135);"># Open-Meteo API se weather data fetch karna</span><span>
</span></span><span><span></span><span class="token token" style="color: rgb(110, 118, 135);"># Yeh free hai, koi API key nahi chahiye</span><span>
</span></span><span>
</span><span><span>WEATHER_URL </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> </span><span class="token token" style="color: rgb(0, 128, 0);">"https://api.open-meteo.com/v1/forecast"</span><span>
</span></span><span>
</span><span><span></span><span class="token token" style="color: rgb(129, 0, 194);">def</span><span> </span><span class="token token" style="color: rgb(0, 81, 194);">get_weather_data</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span>latitude</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(179, 74, 0);">float</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span> longitude</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(179, 74, 0);">float</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span> city</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(179, 74, 0);">str</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span>
</span></span><span><span>    </span><span class="token token triple-quoted-string" style="color: rgb(0, 128, 0);">"""
</span></span><span>    Kisi bhi city ka weather data fetch karo
</span><span>    latitude, longitude — city ki location
</span><span><span class="token token triple-quoted-string" style="color: rgb(0, 128, 0);">    """</span><span>
</span></span><span><span>    params </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> </span><span class="token token" style="color: rgb(43, 48, 59);">{</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"latitude"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> latitude</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"longitude"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> longitude</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"hourly"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span>
</span></span><span><span>            </span><span class="token token" style="color: rgb(0, 128, 0);">"temperature_2m"</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>            </span><span class="token token" style="color: rgb(0, 128, 0);">"windspeed_10m"</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>            </span><span class="token token" style="color: rgb(0, 128, 0);">"cloudcover"</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"forecast_days"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(0, 128, 128);">2</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"timezone"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> </span><span class="token token" style="color: rgb(0, 128, 0);">"Europe/Berlin"</span><span>
</span></span><span><span>    </span><span class="token token" style="color: rgb(43, 48, 59);">}</span><span>
</span></span><span>
</span><span><span>    response </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> requests</span><span class="token token" style="color: rgb(43, 48, 59);">.</span><span>get</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span>WEATHER_URL</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span> params</span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span>params</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span>
</span></span><span><span>    data </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> response</span><span class="token token" style="color: rgb(43, 48, 59);">.</span><span>json</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span>
</span></span><span>
</span><span><span>    </span><span class="token token" style="color: rgb(129, 0, 194);">return</span><span> </span><span class="token token" style="color: rgb(43, 48, 59);">{</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"city"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> city</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"latitude"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> latitude</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"longitude"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> longitude</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"timezone"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> data</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"timezone"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"hourly_time"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> data</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"hourly"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"time"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"temperature"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> data</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"hourly"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"temperature_2m"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"windspeed"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> data</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"hourly"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"windspeed_10m"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">,</span><span>
</span></span><span><span>        </span><span class="token token" style="color: rgb(0, 128, 0);">"cloudcover"</span><span class="token token" style="color: rgb(43, 48, 59);">:</span><span> data</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"hourly"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span class="token token" style="color: rgb(43, 48, 59);">[</span><span class="token token" style="color: rgb(0, 128, 0);">"cloudcover"</span><span class="token token" style="color: rgb(43, 48, 59);">]</span><span>
</span></span><span><span>    </span><span class="token token" style="color: rgb(43, 48, 59);">}</span><span>
</span></span><span>
</span><span>
