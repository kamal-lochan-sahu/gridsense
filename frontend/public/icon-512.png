</span></span><span><span></span><span class="token token" style="color: rgb(129, 0, 194);">import</span><span> os
</span></span><span>
</span><span><span>load_dotenv</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span>
</span></span><span>
</span><span><span>ENTSOE_API_KEY </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> os</span><span class="token token" style="color: rgb(43, 48, 59);">.</span><span>getenv</span><span class="token token" style="color: rgb(43, 48, 59);">(</span><span class="token token" style="color: rgb(0, 128, 0);">"ENTSOE_API_KEY"</span><span class="token token" style="color: rgb(43, 48, 59);">)</span><span>
</span></span><span><span>ENTSOE_BASE_URL </span><span class="token token" style="color: rgb(20, 24, 31);">=</span><span> </span><span class="token token" style="color: rgb(0, 128, 0);">"https://web-api.tp.entsoe.eu/api"</span><span>
